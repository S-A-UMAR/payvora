# ── Django Core ───────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-real-secure-key-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# ── Database (PostgreSQL / SQLite fallback if empty) ──────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payvora_db

# ── Redis (Celery Broker and Cache Backend) ───────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Monnify API Integration (Virtual Accounts & Funding) ──────
MONNIFY_API_KEY=your_monnify_api_key_here
MONNIFY_SECRET_KEY=your_monnify_secret_key_here
MONNIFY_CONTRACT_CODE=your_monnify_contract_code_here

# ── Paystack API Integration (Checkout Validation) ────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# ── Cloudinary Media Integration ──────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── BigiSub API Integration (VTU Provider) ────────────────────
BIGISUB_API_KEY=your_bigisub_api_key_here
